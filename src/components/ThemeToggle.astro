---
/**
 * ThemeToggle — button that switches between light and dark themes.
 *
 * The actual theme STATE is applied to <html data-theme> by an inline script
 * in BaseLayout.astro (which runs before paint to prevent a flash). This
 * component only renders the button + the small click handler that flips and
 * persists the choice to localStorage.
 *
 * Props: none
 * Used by: src/components/Header.astro
 *
 * Accessibility: aria-label describes the action; the two SVGs (sun/moon) are
 * decorative and toggled purely via CSS based on the active theme.
 */
---

<button
  id="theme-toggle"
  class="grid h-10 w-10 place-items-center rounded-[10px] border border-border bg-bg-subtle text-text transition-colors hover:border-accent"
  aria-label="Toggle dark mode"
  type="button"
>
  <!-- Sun: shown in light mode -->
  <svg class="icon-sun h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
  </svg>
  <!-- Moon: shown in dark mode -->
  <svg class="icon-moon h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<style>
  /* Show only the icon relevant to the CURRENT theme. */
  :global([data-theme="light"]) .icon-moon { display: none; }
  :global([data-theme="dark"]) .icon-sun { display: none; }
</style>

<script>
  // Flip the theme on click and persist the choice.
  // (Initial theme is set pre-paint by the inline script in BaseLayout.)
  const btn = document.getElementById("theme-toggle");
  btn?.addEventListener("click", () => {
    const root = document.documentElement;
    const next = root.getAttribute("data-theme") === "dark" ? "light" : "dark";
    root.setAttribute("data-theme", next);
    localStorage.setItem("theme", next);
  });
</script>
