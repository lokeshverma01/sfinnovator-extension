---
/**
 * Header — sticky top navigation: logo, primary nav links, theme toggle.
 *
 * Nav links come from siteConfig.nav (single source of truth). The bar is
 * sticky with a frosted-glass blur, matching the approved design mockup.
 *
 * Props: none
 * Used by: src/layouts/BaseLayout.astro
 */
import { siteConfig } from "@/lib/siteConfig";
import ThemeToggle from "@/components/ThemeToggle.astro";
---

<header
  class="sticky top-0 z-50 border-b border-border backdrop-blur-md"
  style="background: color-mix(in srgb, var(--bg) 88%, transparent);"
>
  <div class="mx-auto flex h-16 max-w-content items-center justify-between px-6">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 text-[18px] font-bold tracking-tight">
      <span class="inline-block h-2.5 w-2.5 rounded-full bg-accent"></span>
      {siteConfig.name}
    </a>

    <!-- Nav + theme toggle -->
    <nav class="flex items-center gap-8" aria-label="Primary">
      {
        siteConfig.nav.map((item) => (
          <a
            href={item.href}
            class="text-[15px] text-muted transition-colors hover:text-text"
          >
            {item.label}
          </a>
        ))
      }
      <ThemeToggle />
    </nav>
  </div>
</header>
