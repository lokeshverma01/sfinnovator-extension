---
/**
 * SearchBox — static, database-free site search powered by Pagefind.
 *
 * Pagefind indexes the built HTML at the end of `astro build` and ships a tiny
 * client bundle + index that runs ENTIRELY in the browser — no server, no DB,
 * works on GitHub Pages. This component renders an input that lazy-loads the
 * Pagefind UI on first focus (so it never costs anything on initial page load).
 *
 * Props:
 *   placeholder? string
 * Used by: blog index, homepage.
 *
 * NOTE: search returns no results in `astro dev` (the index is created at build
 * time). Run `pnpm build && pnpm preview` to test search locally.
 */
import { withBase } from "@/lib/paths";
interface Props {
  placeholder?: string;
}
const { placeholder = "Search posts…" } = Astro.props;

// Pagefind outputs to /pagefind/ at the site root; respect the deploy base.
const pagefindBase = withBase("/pagefind");
---

<div id="search" class="pagefind-host" data-pagefind-base={pagefindBase}>
  <input
    id="search-input"
    type="search"
    placeholder={placeholder}
    aria-label="Search posts"
    autocomplete="off"
    class="w-full rounded-[10px] border border-border bg-bg-subtle px-4 py-2.5 text-[15px] text-text placeholder:text-muted focus:border-accent focus:outline-none"
  />
  <div id="search-results" class="mt-3"></div>
</div>

<script>
  // Lazy-load Pagefind on first interaction to keep initial load fast.
  const host = document.getElementById("search");
  const input = document.getElementById("search-input") as HTMLInputElement | null;
  const results = document.getElementById("search-results");
  if (host && input && results) {
    const base = host.dataset.pagefindBase || "/pagefind";
    let pagefind: any = null;
    let loading = false;

    async function ensureLoaded() {
      if (pagefind || loading) return;
      loading = true;
      try {
        // @ts-ignore — runtime import of the generated Pagefind bundle.
        pagefind = await import(/* @vite-ignore */ `${base}/pagefind.js`);
        await pagefind.options({ baseUrl: "/" });
      } catch (e) {
        results!.innerHTML =
          '<p class="text-sm text-muted">Search is available on the deployed site.</p>';
      }
      loading = false;
    }

    let timer: ReturnType<typeof setTimeout>;
    input.addEventListener("input", async () => {
      await ensureLoaded();
      if (!pagefind) return;
      clearTimeout(timer);
      const q = input.value.trim();
      timer = setTimeout(async () => {
        if (!q) {
          results!.innerHTML = "";
          return;
        }
        const search = await pagefind.search(q);
        const top = await Promise.all(search.results.slice(0, 6).map((r: any) => r.data()));
        results!.innerHTML = top.length
          ? top
              .map(
                (d: any) =>
                  `<a href="${d.url}" class="block rounded border border-border p-3 mb-2 hover:border-accent transition-colors"><span class="font-semibold text-text">${d.meta?.title ?? "Untitled"}</span><span class="block text-sm text-muted mt-1">${d.excerpt}</span></a>`,
              )
              .join("")
          : '<p class="text-sm text-muted">No results.</p>';
      }, 150);
    });
    input.addEventListener("focus", ensureLoaded, { once: true });
  }
</script>
