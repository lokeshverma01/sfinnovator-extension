---
/**
 * PortfolioTile — a card for one portfolio solution. Shows title, summary, tech
 * chips, and quick links (demo/source). Clicking the tile opens its detail page.
 *
 * Props:
 *   entry: CollectionEntry<"portfolio">
 * Used by: src/pages/portfolio/index.astro
 */
import type { CollectionEntry } from "astro:content";
import { withBase } from "@/lib/paths";

interface Props {
  entry: CollectionEntry<"portfolio">;
}
const { entry } = Astro.props;
const d = entry.data;
---

<article
  class="flex flex-col gap-3 rounded border border-border bg-card p-6 shadow-[var(--card-shadow)] transition-transform hover:-translate-y-1 hover:border-accent"
>
  <a href={withBase(`/portfolio/${entry.slug}`)} class="block">
    <h3 class="text-[19px] font-semibold leading-snug tracking-tight">{d.title}</h3>
    <p class="mt-1.5 text-[15px] leading-relaxed text-muted">{d.summary ?? d.description}</p>
  </a>

  {
    d.tech.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {d.tech.map((t) => (
          <span class="rounded-full bg-tag-bg px-2.5 py-0.5 text-xs font-semibold text-tag-text">
            {t}
          </span>
        ))}
      </div>
    )
  }

  <div class="mt-auto flex flex-wrap gap-4 pt-1 text-[14px] font-semibold">
    <a href={withBase(`/portfolio/${entry.slug}`)} class="text-accent hover:underline">
      Details →
    </a>
    {d.demoUrl && <a href={d.demoUrl} class="text-accent hover:underline">Live demo ↗</a>}
    {d.repoUrl && <a href={d.repoUrl} class="text-accent hover:underline">Source ↗</a>}
  </div>
</article>
