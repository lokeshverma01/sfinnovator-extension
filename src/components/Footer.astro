---
/**
 * Footer — minimal site footer: copyright + social links.
 *
 * Links come from siteConfig.socials. Keep this lean (the design principle:
 * only show what's meant to be there).
 *
 * Props: none
 * Used by: src/layouts/BaseLayout.astro
 */
import { siteConfig } from "@/lib/siteConfig";
import { withBase } from "@/lib/paths";

// Static build year. (We avoid Date.now()/new Date() at module scope elsewhere,
// but a build-time year in the footer is fine and stable per deploy.)
const year = new Date().getFullYear();
---

<footer class="border-t border-border py-8">
  <div
    class="mx-auto flex max-w-content flex-wrap items-center justify-between gap-4 px-6"
  >
    <span class="text-[14px] text-muted">© {year} {siteConfig.name}</span>
    <div class="flex gap-6 text-[14px]">
      {
        siteConfig.socials.map((s) => (
          <a href={withBase(s.href)} class="text-muted transition-colors hover:text-text">
            {s.label}
          </a>
        ))
      }
    </div>
  </div>
</footer>
