---
/**
 * BaseHead — everything inside <head> for SEO and social sharing.
 *
 * Centralizes: charset, viewport, title, meta description, canonical link,
 * robots directive, Open Graph + Twitter cards, icons, web manifest, RSS
 * autodiscovery, theme-color, and JSON-LD structured data. Driven by
 * resolveSeo() so every page is consistent and deploy-aware.
 *
 * Props: SeoInput + optional `article` block for blog posts:
 *   title?, description?, path?, image?, imageAlt?, type?, noindex?
 *   article? { publishDate, updatedDate?, section?, tags? }  → emits Article
 *                                                               JSON-LD + OG
 *                                                               article meta
 *   breadcrumbs? [{name, path}]                              → Breadcrumb JSON-LD
 * Used by: src/layouts/BaseLayout.astro
 */
import {
  resolveSeo,
  websiteJsonLd,
  articleJsonLd,
  breadcrumbJsonLd,
  type SeoInput,
} from "@/lib/seo";
import { siteConfig } from "@/lib/siteConfig";
import { withBase } from "@/lib/paths";

interface Props extends SeoInput {
  /** When present, this page is a blog post: emit Article schema + OG article meta. */
  article?: {
    publishDate: Date;
    updatedDate?: Date;
    section?: string;
    tags?: string[];
  };
  /** Optional breadcrumb trail for richer search results. */
  breadcrumbs?: { name: string; path: string }[];
}

const { article, breadcrumbs, ...seoInput } = Astro.props;
const seo = resolveSeo(seoInput);

// Build the JSON-LD graph: always the WebSite/Person; Article + Breadcrumbs when relevant.
const jsonLdBlocks: object[] = [websiteJsonLd()];
if (article) {
  jsonLdBlocks.push(
    articleJsonLd({
      title: seoInput.title ?? siteConfig.name,
      description: seo.description,
      path: seoInput.path ?? "/",
      image: seoInput.image,
      publishDate: article.publishDate,
      updatedDate: article.updatedDate,
    }),
  );
}
if (breadcrumbs && breadcrumbs.length > 0) {
  jsonLdBlocks.push(breadcrumbJsonLd(breadcrumbs));
}

const robots = seo.noindex
  ? "noindex, nofollow"
  : "index, follow, max-image-preview:large";
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content={siteConfig.themeColor} />

<!-- Primary SEO -->
<title>{seo.title}</title>
<meta name="description" content={seo.description} />
<meta name="robots" content={robots} />
<link rel="canonical" href={seo.canonical} />

<!-- Open Graph (Facebook, LinkedIn, etc.) -->
<meta property="og:type" content={seo.type} />
<meta property="og:title" content={seo.title} />
<meta property="og:description" content={seo.description} />
<meta property="og:url" content={seo.canonical} />
<meta property="og:image" content={seo.image} />
<meta property="og:image:alt" content={seo.imageAlt} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content={siteConfig.name} />
<meta property="og:locale" content={siteConfig.locale} />

{/* Article-specific Open Graph (only on blog posts) */}
{
  article && (
    <>
      <meta
        property="article:published_time"
        content={article.publishDate.toISOString()}
      />
      {article.updatedDate && (
        <meta
          property="article:modified_time"
          content={article.updatedDate.toISOString()}
        />
      )}
      {article.section && (
        <meta property="article:section" content={article.section} />
      )}
      {article.tags?.map((tag) => (
        <meta property="article:tag" content={tag} />
      ))}
    </>
  )
}

<!-- Twitter / X card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={seo.title} />
<meta name="twitter:description" content={seo.description} />
<meta name="twitter:image" content={seo.image} />
<meta name="twitter:image:alt" content={seo.imageAlt} />
<meta name="twitter:site" content={siteConfig.author.twitter} />
<meta name="twitter:creator" content={siteConfig.author.twitter} />

<!-- Icons + manifest + feeds -->
<link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
<link rel="manifest" href={withBase("/manifest.webmanifest")} />
<link
  rel="alternate"
  type="application/rss+xml"
  title={`${siteConfig.name} — Blog`}
  href={withBase("/rss.xml")}
/>
<link rel="sitemap" href={withBase("/sitemap-index.xml")} />

<!-- Structured data (JSON-LD) -->
{
  jsonLdBlocks.map((block) => (
    <script type="application/ld+json" set:html={JSON.stringify(block)} />
  ))
}
