---
/**
 * 404.astro — custom "page not found" page.
 *
 * GitHub Pages automatically serves /404.html for unknown routes, so this gives
 * lost visitors a branded, useful page instead of a generic error. Marked
 * noindex (we never want error pages in search results).
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import { withBase } from "@/lib/paths";
---

<BaseLayout
  title="Page not found"
  description="The page you’re looking for doesn’t exist."
  path="/404"
  noindex={true}
>
  <section class="px-6 py-24 text-center">
    <div class="mx-auto max-w-reading">
      <p class="mb-4 text-[15px] font-semibold uppercase tracking-wide text-accent">
        404
      </p>
      <h1 class="mb-6 text-[clamp(28px,4vw,40px)] font-extrabold tracking-tight">
        This page wandered off.
      </h1>
      <p class="mb-8 text-muted">
        The page you’re looking for doesn’t exist or may have moved.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href={withBase("/")}
          class="inline-flex items-center gap-2 rounded-[10px] bg-accent px-[22px] py-3 text-[15px] font-semibold text-accent-contrast transition-transform hover:-translate-y-0.5"
        >
          ← Back home
        </a>
        <a
          href={withBase("/blog")}
          class="inline-flex items-center gap-2 rounded-[10px] border border-border px-[22px] py-3 text-[15px] font-semibold text-text transition-colors hover:border-accent"
        >
          Browse the blog
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
