---
/**
 * /about — about the site/author. Static content; edit the prose below freely.
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/lib/siteConfig";
import { withBase } from "@/lib/paths";
---

<BaseLayout
  title="About"
  description={`About ${siteConfig.name} — a Salesforce learning blog sharing implementations, use cases, and debugging.`}
  path="/about"
>
  <section class="px-6 py-12">
    <div class="mx-auto max-w-reading">
      <h1 class="mb-6 text-[clamp(28px,4vw,42px)] font-extrabold tracking-tight">About</h1>
      <div class="prose">
        <p>
          <strong>{siteConfig.name}</strong> is a Salesforce learning blog. I document
          what I build and debug so others can follow the exact steps — covering
          end-to-end implementations, real-world use cases, and error resolutions.
        </p>
        <h2>What you'll find here</h2>
        <ul>
          <li><strong>Implementations</strong> — building out-of-the-box features, step by step.</li>
          <li><strong>Use cases</strong> — solving real business scenarios with Salesforce.</li>
          <li><strong>Debugging</strong> — symptom → root cause → resolution for common errors.</li>
        </ul>
        <p>
          Browse the <a href={withBase("/blog")}>blog</a> or explore the
          <a href={withBase("/portfolio")}>portfolio</a> to see solutions you can try.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
