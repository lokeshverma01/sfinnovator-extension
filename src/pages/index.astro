---
/**
 * index.astro — the landing page (home).
 *
 * Sections (per the approved mockup): hero with eyebrow + headline + subline +
 * two CTAs, then a "Latest posts" grid of PostCards.
 *
 * Posts are read from the `blog` content collection. While no real posts exist
 * yet, we fall back to placeholder cards so the layout is visible. Once you add
 * .mdx files to src/content/blog/, they replace the placeholders automatically.
 */
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import { formatDate } from "@/lib/utils";
import { withBase } from "@/lib/paths";

// Pull published (non-draft) posts, newest first, max 3 for the landing grid.
const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

// Placeholder cards shown only until real posts exist (matches the mockup).
const placeholders = [
  {
    title: "Setting up Approval Processes end-to-end",
    excerpt:
      "A complete walkthrough of building a multi-step approval flow with the out-of-the-box tools.",
    category: "Implementation",
    date: "Jun 18, 2026",
    minutes: 8,
    href: "/blog",
  },
  {
    title: "Resolving the Apex CPU Time Limit error",
    excerpt:
      "Root cause analysis of a governor limit breach and three ways to refactor around it.",
    category: "Debugging",
    date: "Jun 12, 2026",
    minutes: 6,
    href: "/blog",
  },
  {
    title: "Auto-assigning cases by region with Flow",
    excerpt:
      "A real scenario: routing inbound cases to the right queue without a single line of code.",
    category: "Use case",
    date: "Jun 05, 2026",
    minutes: 5,
    href: "/blog",
  },
];

const hasPosts = posts.length > 0;
---

<BaseLayout
  title={undefined}
  description="A Salesforce learning blog: end-to-end implementations, real use-case scenarios, error debugging, and solutions you can validate."
  path="/"
>
  <!-- HERO -->
  <section class="px-6 pb-16 pt-24 text-center">
    <div class="mx-auto max-w-content">
      <span
        class="mb-6 inline-block rounded-full bg-tag-bg px-3 py-1.5 text-[13px] font-semibold uppercase tracking-wide text-accent"
      >
        Salesforce · learn by building
      </span>
      <h1
        class="mx-auto mb-6 max-w-[760px] text-[clamp(34px,5vw,56px)] font-extrabold leading-[1.1] tracking-tight"
      >
        Salesforce, explained by building it.
      </h1>
      <p class="mx-auto mb-8 max-w-[600px] text-[clamp(17px,2vw,20px)] text-muted">
        Real implementations, debugged errors, and solutions you can validate —
        written down as I learn them.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href={withBase("/blog")}
          class="inline-flex items-center gap-2 rounded-[10px] bg-accent px-[22px] py-3 text-[15px] font-semibold text-accent-contrast transition-transform hover:-translate-y-0.5"
        >
          Read the blog →
        </a>
        <a
          href={withBase("/portfolio")}
          class="inline-flex items-center gap-2 rounded-[10px] border border-border px-[22px] py-3 text-[15px] font-semibold text-text transition-colors hover:border-accent"
        >
          View portfolio
        </a>
      </div>
    </div>
  </section>

  <!-- LATEST POSTS -->
  <section class="px-6 pb-24 pt-16">
    <div class="mx-auto max-w-content">
      <div class="mb-8 flex items-baseline justify-between">
        <h2 class="text-2xl font-bold tracking-tight">Latest posts</h2>
        <a href={withBase("/blog")} class="text-[14px] text-accent">View all →</a>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {
          hasPosts
            ? posts.map((post) => (
                <PostCard
                  title={post.data.title}
                  excerpt={post.data.description}
                  category={post.data.category}
                  date={formatDate(post.data.publishDate)}
                  minutes={5}
                  href={withBase(`/blog/${post.slug}`)}
                />
              ))
            : placeholders.map((p) => (
                <PostCard
                  title={p.title}
                  excerpt={p.excerpt}
                  category={p.category}
                  date={p.date}
                  minutes={p.minutes}
                  href={withBase(p.href)}
                />
              ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
