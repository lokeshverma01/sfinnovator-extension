---
/**
 * index.astro — the landing page (home).
 *
 * Sections: hero with eyebrow + headline + subline + two CTAs, a search box,
 * then a "Latest posts" grid of the 3 newest published posts (real content from
 * the blog collection). When there are no posts yet, the grid is simply hidden.
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import SearchBox from "@/components/SearchBox.astro";
import { getPublishedPosts, postReadingTime } from "@/lib/posts";
import { formatDate } from "@/lib/utils";
import { withBase } from "@/lib/paths";

// 3 newest published posts for the landing grid.
const posts = (await getPublishedPosts()).slice(0, 3);
const hasPosts = posts.length > 0;
---

<BaseLayout
  title={undefined}
  description="A Salesforce learning blog: end-to-end implementations, real use-case scenarios, error debugging, and solutions you can validate."
  path="/"
>
  <!-- HERO -->
  <section class="px-6 pb-16 pt-24 text-center">
    <div class="mx-auto max-w-content">
      <span
        class="mb-6 inline-block rounded-full bg-tag-bg px-3 py-1.5 text-[13px] font-semibold uppercase tracking-wide text-accent"
      >
        Salesforce · learn by building
      </span>
      <h1
        class="mx-auto mb-6 max-w-[760px] text-[clamp(34px,5vw,56px)] font-extrabold leading-[1.1] tracking-tight"
      >
        Salesforce, explained by building it.
      </h1>
      <p class="mx-auto mb-8 max-w-[600px] text-[clamp(17px,2vw,20px)] text-muted">
        Real implementations, debugged errors, and solutions you can validate —
        written down as I learn them.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href={withBase("/blog")}
          class="inline-flex items-center gap-2 rounded-[10px] bg-accent px-[22px] py-3 text-[15px] font-semibold text-accent-contrast transition-transform hover:-translate-y-0.5"
        >
          Read the blog →
        </a>
        <a
          href={withBase("/portfolio")}
          class="inline-flex items-center gap-2 rounded-[10px] border border-border px-[22px] py-3 text-[15px] font-semibold text-text transition-colors hover:border-accent"
        >
          View portfolio
        </a>
      </div>

      <!-- Search -->
      <div class="mx-auto mt-10 max-w-[560px] text-left">
        <SearchBox placeholder="Search posts — e.g. 'CPU time limit'…" />
      </div>
    </div>
  </section>

  <!-- LATEST POSTS -->
  {
    hasPosts && (
      <section class="px-6 pb-24 pt-8">
        <div class="mx-auto max-w-content">
          <div class="mb-8 flex items-baseline justify-between">
            <h2 class="text-2xl font-bold tracking-tight">Latest posts</h2>
            <a href={withBase("/blog")} class="text-[14px] text-accent">
              View all →
            </a>
          </div>

          <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
            {posts.map((post) => (
              <PostCard
                title={post.data.title}
                excerpt={post.data.description}
                category={post.data.category[0]}
                date={formatDate(post.data.publishDate)}
                minutes={postReadingTime(post)}
                href={withBase(`/blog/${post.slug}`)}
              />
            ))}
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>
