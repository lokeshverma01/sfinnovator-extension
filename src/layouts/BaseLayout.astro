---
/**
 * BaseLayout — the page shell shared by every page.
 *
 * Responsibilities:
 *  - Renders <html>, <head> (via BaseHead), and <body> with Header + Footer.
 *  - Applies the no-flash theme script BEFORE paint.
 *  - Provides a centered <main> content slot.
 *
 * Props: SeoInput + optional article/breadcrumbs (all passed straight through
 *        to BaseHead) — title?, description?, path?, image?, imageAlt?, type?,
 *        noindex?, article?, breadcrumbs?
 * Used by: every page in src/pages/
 */
import "@/styles/global.css";
import BaseHead from "@/components/BaseHead.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { siteConfig } from "@/lib/siteConfig";
import type { SeoInput } from "@/lib/seo";

interface Props extends SeoInput {
  article?: {
    publishDate: Date;
    updatedDate?: Date;
    section?: string;
    tags?: string[];
  };
  breadcrumbs?: { name: string; path: string }[];
}

// <html lang> from config (BCP-47 → strip region for the lang attribute).
const htmlLang = siteConfig.locale.split("_")[0];
---

<!doctype html>
<html lang={htmlLang} data-theme="light">
  <head>
    <BaseHead {...Astro.props} />

    {/*
      No-flash theme script. Runs synchronously in <head> BEFORE the body
      paints, so the correct theme is applied with no flicker. Priority:
      1) the user's saved choice (localStorage), else
      2) the OS preference (prefers-color-scheme).
      `is:inline` tells Astro to emit this verbatim, not bundle/defer it.
    */}
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem("theme");
          var theme =
            saved ||
            (window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light");
          document.documentElement.setAttribute("data-theme", theme);
        } catch (e) {
          /* localStorage blocked — fall back to the default light theme. */
        }
      })();
    </script>
  </head>

  <body class="min-h-screen">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
